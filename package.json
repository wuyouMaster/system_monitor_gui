{
  "name": "system-monitor",
  "version": "1.0.0",
  "description": "A futuristic system monitor powered by Rust and Electron",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "build:rust": "cd ../query_system_info/js-abi && yarn install && yarn build",
    "copy:native": "node scripts/copy-native.js",
    "predev": "npm run copy:native",
    "preview": "vite preview",
    "electron:dev": "npm run build:rust && npm run copy:native && vite",
    "electron:build": "vite build && electron-builder"
  },
  "dependencies": {
    "@emotion/react": "^11.11.0",
    "@emotion/styled": "^11.11.0",
    "@mui/icons-material": "^5.15.0",
    "@mui/material": "^5.15.0",
    "@tanstack/react-virtual": "^3.13.21",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "recharts": "^2.10.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.systemmonitor.app",
    "productName": "System Monitor",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "public/**/*"
    ],
    "extraResources": [
      {
        "from": "../query_system_info/dist",
        "to": "native",
        "filter": [
          "**/*.node"
        ]
      }
    ]
  }
}
